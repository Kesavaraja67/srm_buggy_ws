<?xml version="1.0"?>
<robot name="srm_aquila_buggy" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    SRM Autonomous Electric Campus Buggy  v3.0
    Based on: Aquila EV TE-A6+2 (Tri Electric Pvt Ltd, Tamil Nadu)
    FIXES in v3.0:
      - Pillars: z origin fixed so they sit between chassis and roof
      - Roof: height corrected so pillars connect
      - LiDAR: now bolted flush ON TOP of roof (not floating)
      - Camera: repositioned to front face of chassis at correct height
      - Steering: rebuilt as proper column + wheel assembly
      - Mirrors: rebuilt from scratch — properly attached to pillar base
      - Seats: Gazebo material overrides added so brown shows correctly
      - All sensor positions verified relative to base_link
  -->

  <!-- ═══════════════════════════════
       PROPERTIES
  ═══════════════════════════════ -->
  <xacro:property name="cl"   value="4.12"/>   <!-- chassis length -->
  <xacro:property name="cw"   value="1.20"/>   <!-- chassis width  -->
  <xacro:property name="ch"   value="0.25"/>   <!-- chassis height -->
  <xacro:property name="cz"   value="0.425"/>  <!-- ride height (base_link above ground) -->

  <xacro:property name="wr"   value="0.26"/>   <!-- wheel radius -->
  <xacro:property name="ww"   value="0.205"/>  <!-- wheel width  -->

  <!-- Pillar geometry:
       Bottom of pillar = chassis top = cz + ch/2 above ground = 0.425+0.125=0.55m
       Roof bottom      = 1.90 - cz  = 1.475m above base_link
       Pillar length    = 1.475 - 0.125 = 1.35m
       Pillar centre z  = 0.125 + 1.35/2 = 0.80m above base_link -->
  <xacro:property name="pillar_h"  value="1.35"/>
  <xacro:property name="pillar_cz" value="0.80"/>
  <xacro:property name="pillar_r"  value="0.04"/>

  <!-- Roof: sits at 1.475m above base_link (1.9m total height - 0.425 ride height) -->
  <xacro:property name="roof_z"  value="1.475"/>
  <xacro:property name="roof_t"  value="0.06"/>

  <!-- Seat geometry -->
  <xacro:property name="sl"  value="0.45"/>
  <xacro:property name="sw"  value="0.48"/>
  <xacro:property name="sh"  value="0.12"/>
  <xacro:property name="brh" value="0.50"/>
  <xacro:property name="brt" value="0.08"/>

  <!-- ═══════════════════════════════
       MATERIALS
  ═══════════════════════════════ -->
  <material name="white">        <color rgba="0.96 0.96 0.96 1.0"/></material>
  <material name="srm_blue">     <color rgba="0.05 0.25 0.65 1.0"/></material>
  <material name="dark_grey">    <color rgba="0.18 0.18 0.18 1.0"/></material>
  <material name="mid_grey">     <color rgba="0.45 0.45 0.45 1.0"/></material>
  <material name="chassis_blk">  <color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="brown">        <color rgba="0.55 0.28 0.08 1.0"/></material>
  <material name="black_tyre">   <color rgba="0.08 0.08 0.08 1.0"/></material>
  <material name="silver">       <color rgba="0.78 0.78 0.82 1.0"/></material>
  <material name="clear">        <color rgba="0.80 0.90 1.00 0.25"/></material>
  <material name="lidar_silver"> <color rgba="0.82 0.82 0.85 1.0"/></material>
  <material name="lidar_blue">   <color rgba="0.10 0.50 0.90 1.0"/></material>
  <material name="rs_grey">      <color rgba="0.55 0.58 0.62 1.0"/></material>
  <material name="rs_black">     <color rgba="0.10 0.10 0.12 1.0"/></material>
  <material name="lens_green">   <color rgba="0.20 0.65 0.35 1.0"/></material>
  <material name="pcb_green">    <color rgba="0.10 0.35 0.15 1.0"/></material>
  <material name="gps_white">    <color rgba="0.90 0.90 0.90 1.0"/></material>
  <material name="us_blue">      <color rgba="0.15 0.30 0.70 1.0"/></material>
  <material name="hl_white">     <color rgba="0.95 0.95 0.80 1.0"/></material>
  <material name="tl_red">       <color rgba="0.90 0.10 0.10 1.0"/></material>

  <!-- Inertial helper macro for visual-only links -->
  <xacro:macro name="tiny_inertial">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </xacro:macro>

  <!-- ═══════════════════════════════
       BASE FOOTPRINT
  ═══════════════════════════════ -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/>
    <origin xyz="0 0 ${cz}" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════
       CHASSIS
  ═══════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry><box size="${cl} ${cw} ${ch}"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><box size="${cl} ${cw} ${ch}"/></geometry>
    </collision>
    <inertial>
      <mass value="280.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="80" ixy="0" ixz="0" iyy="400" iyz="0" izz="450"/>
    </inertial>
  </link>
  <gazebo reference="base_link"><material>Gazebo/White</material></gazebo>

  <!-- SRM Blue accent stripes — flush with side faces -->
  <joint name="stripe_l_jt" type="fixed">
    <parent link="base_link"/><child link="stripe_l"/>
    <origin xyz="0.10 ${cw/2 + 0.002} 0.06" rpy="0 0 0"/>
  </joint>
  <link name="stripe_l">
    <visual><geometry><box size="${cl - 0.4} 0.005 0.08"/></geometry>
      <material name="srm_blue"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="stripe_l"><material>Gazebo/Blue</material></gazebo>

  <joint name="stripe_r_jt" type="fixed">
    <parent link="base_link"/><child link="stripe_r"/>
    <origin xyz="0.10 ${-(cw/2 + 0.002)} 0.06" rpy="0 0 0"/>
  </joint>
  <link name="stripe_r">
    <visual><geometry><box size="${cl - 0.4} 0.005 0.08"/></geometry>
      <material name="srm_blue"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="stripe_r"><material>Gazebo/Blue</material></gazebo>

  <!-- Frame rails -->
  <joint name="frame_l_jt" type="fixed">
    <parent link="base_link"/><child link="frame_l"/>
    <origin xyz="0 ${cw/2 - 0.08} ${-ch/2 - 0.03}" rpy="0 0 0"/>
  </joint>
  <link name="frame_l">
    <visual><geometry><box size="${cl} 0.06 0.05"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <joint name="frame_r_jt" type="fixed">
    <parent link="base_link"/><child link="frame_r"/>
    <origin xyz="0 ${-(cw/2 - 0.08)} ${-ch/2 - 0.03}" rpy="0 0 0"/>
  </joint>
  <link name="frame_r">
    <visual><geometry><box size="${cl} 0.06 0.05"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- ── Body panels ── -->
  <joint name="front_panel_jt" type="fixed">
    <parent link="base_link"/><child link="front_panel"/>
    <origin xyz="${cl/2} 0 0.10" rpy="0 0 0"/>
  </joint>
  <link name="front_panel">
    <visual><geometry><box size="0.08 ${cw} 0.38"/></geometry>
      <material name="white"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="front_panel"><material>Gazebo/White</material></gazebo>

  <!-- Front bumper (black) -->
  <joint name="front_bump_jt" type="fixed">
    <parent link="base_link"/><child link="front_bump"/>
    <origin xyz="${cl/2 + 0.01} 0 ${-ch/2 + 0.05}" rpy="0 0 0"/>
  </joint>
  <link name="front_bump">
    <visual><geometry><box size="0.10 ${cw + 0.06} 0.12"/></geometry>
      <material name="chassis_blk"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="front_bump"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Rear panel -->
  <joint name="rear_panel_jt" type="fixed">
    <parent link="base_link"/><child link="rear_panel"/>
    <origin xyz="${-cl/2} 0 0.10" rpy="0 0 0"/>
  </joint>
  <link name="rear_panel">
    <visual><geometry><box size="0.08 ${cw} 0.35"/></geometry>
      <material name="white"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- Rear bumper (black) -->
  <joint name="rear_bump_jt" type="fixed">
    <parent link="base_link"/><child link="rear_bump"/>
    <origin xyz="${-cl/2 - 0.01} 0 ${-ch/2 + 0.05}" rpy="0 0 0"/>
  </joint>
  <link name="rear_bump">
    <visual><geometry><box size="0.10 ${cw + 0.06} 0.12"/></geometry>
      <material name="chassis_blk"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- Side panels -->
  <joint name="side_l_jt" type="fixed">
    <parent link="base_link"/><child link="side_l"/>
    <origin xyz="0.15 ${cw/2 + 0.002} 0.15" rpy="0 0 0"/>
  </joint>
  <link name="side_l">
    <visual><geometry><box size="${cl - 0.6} 0.04 0.48"/></geometry>
      <material name="white"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <joint name="side_r_jt" type="fixed">
    <parent link="base_link"/><child link="side_r"/>
    <origin xyz="0.15 ${-(cw/2 + 0.002)} 0.15" rpy="0 0 0"/>
  </joint>
  <link name="side_r">
    <visual><geometry><box size="${cl - 0.6} 0.04 0.48"/></geometry>
      <material name="white"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- ═══════════════════════════════
       ROOF PILLARS — FIXED
       Each pillar runs from chassis top to roof bottom.
       Origin = pillar centre in base_link frame.
       Bottom of pillar = ch/2 = 0.125m above base_link
       Top of pillar    = roof_z = 1.475m above base_link
       Centre of pillar = (0.125 + 1.475)/2 = 0.80m
       Length           = 1.475 - 0.125 = 1.35m
  ═══════════════════════════════ -->
  <!-- Front-left -->
  <joint name="pfl_jt" type="fixed">
    <parent link="base_link"/><child link="pfl"/>
    <origin xyz="${cl/2 - 0.32} ${cw/2 - 0.06} ${pillar_cz}" rpy="0 0 0"/>
  </joint>
  <link name="pfl">
    <visual><geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="pfl"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Front-right -->
  <joint name="pfr_jt" type="fixed">
    <parent link="base_link"/><child link="pfr"/>
    <origin xyz="${cl/2 - 0.32} ${-(cw/2 - 0.06)} ${pillar_cz}" rpy="0 0 0"/>
  </joint>
  <link name="pfr">
    <visual><geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="pfr"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Rear-left -->
  <joint name="prl_jt" type="fixed">
    <parent link="base_link"/><child link="prl"/>
    <origin xyz="${-(cl/2 - 0.32)} ${cw/2 - 0.06} ${pillar_cz}" rpy="0 0 0"/>
  </joint>
  <link name="prl">
    <visual><geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="prl"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- Rear-right -->
  <joint name="prr_jt" type="fixed">
    <parent link="base_link"/><child link="prr"/>
    <origin xyz="${-(cl/2 - 0.32)} ${-(cw/2 - 0.06)} ${pillar_cz}" rpy="0 0 0"/>
  </joint>
  <link name="prr">
    <visual><geometry><cylinder radius="${pillar_r}" length="${pillar_h}"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="prr"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ═══════════════════════════════
       ROOF — sits exactly at pillar tops
       z = roof_z = 1.475m above base_link
  ═══════════════════════════════ -->
  <joint name="roof_jt" type="fixed">
    <parent link="base_link"/><child link="roof"/>
    <origin xyz="-0.10 0 ${roof_z}" rpy="0 0 0"/>
  </joint>
  <link name="roof">
    <visual>
      <geometry><box size="3.20 ${cw + 0.12} ${roof_t}"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><box size="3.20 ${cw + 0.12} ${roof_t}"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="2" ixy="0" ixz="0" iyy="5" iyz="0" izz="6"/>
    </inertial>
  </link>
  <gazebo reference="roof"><material>Gazebo/White</material></gazebo>

  <!-- Roof dark trim -->
  <joint name="roof_trim_jt" type="fixed">
    <parent link="roof"/><child link="roof_trim"/>
    <origin xyz="0 0 ${-roof_t/2 - 0.012}" rpy="0 0 0"/>
  </joint>
  <link name="roof_trim">
    <visual><geometry><box size="3.26 ${cw + 0.18} 0.025"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="roof_trim"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ═══════════════════════════════
       SRM LOGO on roof top
  ═══════════════════════════════ -->
  <joint name="logo_jt" type="fixed">
    <parent link="roof"/><child link="logo"/>
    <origin xyz="0.3 0 ${roof_t/2 + 0.012}" rpy="0 0 0"/>
  </joint>
  <link name="logo">
    <visual><geometry><box size="0.28 0.28 0.018"/></geometry>
      <material name="srm_blue"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="logo"><material>Gazebo/Blue</material></gazebo>

  <joint name="logo_ring_jt" type="fixed">
    <parent link="roof"/><child link="logo_ring"/>
    <origin xyz="0.3 0 ${roof_t/2 + 0.020}" rpy="0 0 0"/>
  </joint>
  <link name="logo_ring">
    <visual><geometry><cylinder radius="0.11" length="0.008"/></geometry>
      <material name="srm_blue"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <joint name="logo_circle_jt" type="fixed">
    <parent link="roof"/><child link="logo_circle"/>
    <origin xyz="0.3 0 ${roof_t/2 + 0.024}" rpy="0 0 0"/>
  </joint>
  <link name="logo_circle">
    <visual><geometry><cylinder radius="0.09" length="0.008"/></geometry>
      <material name="white"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- ═══════════════════════════════
       WINDSHIELD — slanted front glass
  ═══════════════════════════════ -->
  <joint name="ws_jt" type="fixed">
    <parent link="base_link"/><child link="windshield"/>
    <origin xyz="${cl/2 - 0.45} 0 0.72" rpy="0 -0.32 0"/>
  </joint>
  <link name="windshield">
    <visual><geometry><box size="0.02 ${cw - 0.06} 0.62"/></geometry>
      <material name="clear"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- ═══════════════════════════════
       DASHBOARD — dark panel at front
  ═══════════════════════════════ -->
  <joint name="dash_jt" type="fixed">
    <parent link="base_link"/><child link="dashboard"/>
    <origin xyz="${cl/2 - 0.58} 0 0.35" rpy="0 0.38 0"/>
  </joint>
  <link name="dashboard">
    <visual><geometry><box size="0.06 ${cw - 0.12} 0.32"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="dashboard"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ── STEERING — FIXED ──
       Column runs from dashboard upward-forward.
       Wheel is a flat disc at the top.
       All positioned relative to base_link.
  -->
  <!-- Steering column base -->
  <joint name="stcol_jt" type="fixed">
    <parent link="base_link"/><child link="stcol"/>
    <origin xyz="${cl/2 - 0.52} 0.25 0.48" rpy="0 -0.55 0"/>
  </joint>
  <link name="stcol">
    <visual><geometry><cylinder radius="0.022" length="0.32"/></geometry>
      <material name="dark_grey"/></visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- Steering wheel — flat disc at end of column
       Position = column base + offset along column axis
       Column tilted -0.55 rad (≈31.5°), length 0.32/2=0.16
       dx = 0.16*cos(0.55)=0.138, dz = 0.16*sin(0.55)=0.083 -->
  <joint name="stwheel_jt" type="fixed">
    <parent link="base_link"/><child link="stwheel"/>
    <origin xyz="${cl/2 - 0.52 + 0.138} 0.25 ${0.48 + 0.083}" rpy="0 1.018 0"/>
  </joint>
  <link name="stwheel">
    <!-- Outer ring -->
    <visual>
      <geometry><cylinder radius="0.175" length="0.020"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Inner hub -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.040" length="0.022"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Spoke horizontal -->
    <visual>
      <geometry><box size="0.280 0.020 0.018"/></geometry>
      <material name="mid_grey"/>
    </visual>
    <!-- Spoke vertical -->
    <visual>
      <geometry><box size="0.018 0.020 0.280"/></geometry>
      <material name="mid_grey"/>
    </visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="stwheel"><material>Gazebo/DarkGrey</material></gazebo>

  <!-- ═══════════════════════════════
       SIDE MIRRORS — FIXED
       Mirrors attach directly to front-left and front-right pillars
       at mid-height, extending outward in Y.
  ═══════════════════════════════ -->

  <!-- Left mirror — attaches to left pillar x-position, at z=0.50 -->
  <joint name="mir_l_jt" type="fixed">
    <parent link="base_link"/><child link="mir_l_arm"/>
    <origin xyz="${cl/2 - 0.32} ${cw/2 + 0.01} 0.50" rpy="0 0 0"/>
  </joint>
  <link name="mir_l_arm">
    <!-- Arm extending outward -->
    <visual>
      <origin xyz="0 0.10 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.20 0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Mirror head at end of arm -->
    <visual>
      <origin xyz="0 0.22 0.02" rpy="0 0 0"/>
      <geometry><box size="0.095 0.030 0.075"/></geometry>
      <material name="chassis_blk"/>
    </visual>
    <!-- Reflective glass face (silver) -->
    <visual>
      <origin xyz="0.050 0.220 0.020" rpy="0 0 0"/>
      <geometry><box size="0.004 0.025 0.065"/></geometry>
      <material name="silver"/>
    </visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- Right mirror -->
  <joint name="mir_r_jt" type="fixed">
    <parent link="base_link"/><child link="mir_r_arm"/>
    <origin xyz="${cl/2 - 0.32} ${-(cw/2 + 0.01)} 0.50" rpy="0 0 0"/>
  </joint>
  <link name="mir_r_arm">
    <visual>
      <origin xyz="0 -0.10 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.20 0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0 -0.22 0.02" rpy="0 0 0"/>
      <geometry><box size="0.095 0.030 0.075"/></geometry>
      <material name="chassis_blk"/>
    </visual>
    <visual>
      <origin xyz="0.050 -0.220 0.020" rpy="0 0 0"/>
      <geometry><box size="0.004 0.025 0.065"/></geometry>
      <material name="silver"/>
    </visual>
    <xacro:tiny_inertial/>
  </link>

  <!-- ═══════════════════════════════
       LIGHTS
  ═══════════════════════════════ -->
  <!-- Headlights — square LED style, front face -->
  <joint name="hl_l_jt" type="fixed">
    <parent link="base_link"/><child link="hl_l"/>
    <origin xyz="${cl/2 + 0.01} 0.33 0.15" rpy="0 1.5708 0"/>
  </joint>
  <link name="hl_l">
    <visual><geometry><box size="0.05 0.12 0.055"/></geometry>
      <material name="hl_white"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="hl_l"><material>Gazebo/Yellow</material></gazebo>

  <joint name="hl_r_jt" type="fixed">
    <parent link="base_link"/><child link="hl_r"/>
    <origin xyz="${cl/2 + 0.01} -0.33 0.15" rpy="0 1.5708 0"/>
  </joint>
  <link name="hl_r">
    <visual><geometry><box size="0.05 0.12 0.055"/></geometry>
      <material name="hl_white"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="hl_r"><material>Gazebo/Yellow</material></gazebo>

  <!-- Tail lights — red -->
  <joint name="tl_l_jt" type="fixed">
    <parent link="base_link"/><child link="tl_l"/>
    <origin xyz="${-cl/2 - 0.01} 0.36 0.12" rpy="0 1.5708 0"/>
  </joint>
  <link name="tl_l">
    <visual><geometry><box size="0.035 0.10 0.048"/></geometry>
      <material name="tl_red"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="tl_l"><material>Gazebo/Red</material></gazebo>

  <joint name="tl_r_jt" type="fixed">
    <parent link="base_link"/><child link="tl_r"/>
    <origin xyz="${-cl/2 - 0.01} -0.36 0.12" rpy="0 1.5708 0"/>
  </joint>
  <link name="tl_r">
    <visual><geometry><box size="0.035 0.10 0.048"/></geometry>
      <material name="tl_red"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="tl_r"><material>Gazebo/Red</material></gazebo>

  <!-- ═══════════════════════════════
       SEATS — Brown leather
       Gazebo material overrides ensure colour shows
  ═══════════════════════════════ -->
  <xacro:macro name="seat" params="name px py">
    <joint name="${name}_c_jt" type="fixed">
      <parent link="base_link"/><child link="${name}_c"/>
      <origin xyz="${px} ${py} ${ch/2 + sh/2}" rpy="0 0 0"/>
    </joint>
    <link name="${name}_c">
      <visual><geometry><box size="${sl} ${sw} ${sh}"/></geometry>
        <material name="brown"/></visual>
      <xacro:tiny_inertial/>
    </link>
    <gazebo reference="${name}_c"><material>Gazebo/Brown</material></gazebo>

    <joint name="${name}_b_jt" type="fixed">
      <parent link="base_link"/><child link="${name}_b"/>
      <origin xyz="${px - sl/2 + brt/2} ${py} ${ch/2 + sh + brh/2}" rpy="0 0 0"/>
    </joint>
    <link name="${name}_b">
      <visual><geometry><box size="${brt} ${sw} ${brh}"/></geometry>
        <material name="brown"/></visual>
      <xacro:tiny_inertial/>
    </link>
    <gazebo reference="${name}_b"><material>Gazebo/Brown</material></gazebo>
  </xacro:macro>

  <xacro:seat name="s1l" px="1.20"  py=" 0.28"/>
  <xacro:seat name="s1r" px="1.20"  py="-0.28"/>
  <xacro:seat name="s2l" px="0.30"  py=" 0.28"/>
  <xacro:seat name="s2r" px="0.30"  py="-0.28"/>
  <xacro:seat name="s3l" px="-0.55" py=" 0.28"/>
  <xacro:seat name="s3r" px="-0.55" py="-0.28"/>

  <!-- Rear bench -->
  <joint name="rear_c_jt" type="fixed">
    <parent link="base_link"/><child link="rear_c"/>
    <origin xyz="-1.40 0 ${ch/2 + sh/2}" rpy="0 0 0"/>
  </joint>
  <link name="rear_c">
    <visual><geometry><box size="${sl} ${cw - 0.20} ${sh}"/></geometry>
      <material name="brown"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="rear_c"><material>Gazebo/Brown</material></gazebo>

  <joint name="rear_b_jt" type="fixed">
    <parent link="base_link"/><child link="rear_b"/>
    <origin xyz="-1.20 0 ${ch/2 + sh + brh/2}" rpy="0 0 3.14159"/>
  </joint>
  <link name="rear_b">
    <visual><geometry><box size="${brt} ${cw - 0.20} ${brh}"/></geometry>
      <material name="brown"/></visual>
    <xacro:tiny_inertial/>
  </link>
  <gazebo reference="rear_b"><material>Gazebo/Brown</material></gazebo>

  <!-- ═══════════════════════════════
       WHEELS
  ═══════════════════════════════ -->
  <xacro:macro name="wheel" params="name px py side">
    <joint name="${name}_jt" type="continuous">
      <parent link="base_link"/><child link="${name}"/>
      <origin xyz="${px} ${py} ${-(ch/2 + 0.04)}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.5" friction="0.5"/>
    </joint>
    <link name="${name}">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wr}" length="${ww}"/></geometry>
        <material name="black_tyre"/>
      </visual>
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.127" length="${ww + 0.01}"/></geometry>
        <material name="silver"/>
      </visual>
      <visual>
        <origin xyz="0 ${side*(ww/2 + 0.005)} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.055" length="0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <!-- 3 spokes -->
      <visual>
        <origin xyz="0 ${side*(ww/2 + 0.008)} 0" rpy="1.5708 0 0"/>
        <geometry><box size="0.22 0.018 0.018"/></geometry>
        <material name="mid_grey"/>
      </visual>
      <visual>
        <origin xyz="0 ${side*(ww/2 + 0.008)} 0" rpy="1.5708 0.628 0"/>
        <geometry><box size="0.22 0.018 0.018"/></geometry>
        <material name="mid_grey"/>
      </visual>
      <visual>
        <origin xyz="0 ${side*(ww/2 + 0.008)} 0" rpy="1.5708 1.257 0"/>
        <geometry><box size="0.22 0.018 0.018"/></geometry>
        <material name="mid_grey"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wr}" length="${ww}"/></geometry>
      </collision>
      <inertial>
        <mass value="12.0"/>
        <origin rpy="1.5708 0 0"/>
        <inertia ixx="0.4" ixy="0" ixz="0" iyy="0.4" iyz="0" izz="0.7"/>
      </inertial>
    </link>
    <gazebo reference="${name}"><mu1>1.0</mu1><mu2>1.0</mu2><kp>1e6</kp><kd>100</kd><material>Gazebo/Black</material></gazebo>
  </xacro:macro>

  <xacro:wheel name="wfl" px=" 1.30" py=" 0.55" side=" 1"/>
  <xacro:wheel name="wfr" px=" 1.30" py="-0.55" side="-1"/>
  <xacro:wheel name="wrl" px="-1.30" py=" 0.55" side=" 1"/>
  <xacro:wheel name="wrr" px="-1.30" py="-0.55" side="-1"/>

  <!-- ═══════════════════════════════
       LIVOX MID-360 LiDAR — FIXED
       Mounted ON TOP of roof at scan origin z=1.85m above base_link.
       This provides clearance above the roof for unobstructed 360° scanning.
  ═══════════════════════════════ -->
  <joint name="lidar_jt" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <!-- scan origin at 1.85m above base_link, offset -0.10 to align with roof -->
    <origin xyz="-0.10 0.0 1.85" rpy="0 0 0"/>
  </joint>
  <link name="lidar_link">
    <!-- Square silver base — sits on roof surface -->
    <visual>
      <origin xyz="0 0 -0.040" rpy="0 0 0"/>
      <geometry><box size="0.078 0.078 0.045"/></geometry>
      <material name="lidar_silver"/>
    </visual>
    <!-- Mounting ring -->
    <visual>
      <origin xyz="0 0 -0.010" rpy="0 0 0"/>
      <geometry><cylinder radius="0.042" length="0.014"/></geometry>
      <material name="mid_grey"/>
    </visual>
    <!-- Blue hemispherical dome — scan origin = top of this dome -->
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry><sphere radius="0.038"/></geometry>
      <material name="lidar_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.020" rpy="0 0 0"/>
      <geometry><cylinder radius="0.048" length="0.10"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="lidar_link"><material>Gazebo/Blue</material></gazebo>

  <!-- ═══════════════════════════════
       INTEL REALSENSE D435i — FIXED
       Mounted at front face of chassis.
       z = 0.52m above base_link (windshield height, just inside it)
       x = chassis front face = cl/2
  ═══════════════════════════════ -->
  <joint name="camera_jt" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="${cl/2 - 0.02} 0.0 0.52" rpy="0 0 0"/>
  </joint>
  <link name="camera_link">
    <!-- Silver housing — wide horizontal bar (D435i shape) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.028 0.098 0.028"/></geometry>
      <material name="rs_grey"/>
    </visual>
    <!-- Black front face -->
    <visual>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.003 0.094 0.024"/></geometry>
      <material name="rs_black"/>
    </visual>
    <!-- IR left lens -->
    <visual>
      <origin xyz="0.017 -0.034 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.007" length="0.004"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- RGB lens (green) -->
    <visual>
      <origin xyz="0.017 -0.009 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.009" length="0.004"/></geometry>
      <material name="lens_green"/>
    </visual>
    <!-- IR right lens -->
    <visual>
      <origin xyz="0.017 0.016 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.007" length="0.004"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Dot projector -->
    <visual>
      <origin xyz="0.017 0.037 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.005" length="0.003"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.028 0.098 0.028"/></geometry>
    </collision>
    <inertial>
      <mass value="0.07"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════
       BNO055 IMU — inside chassis at centroid
  ═══════════════════════════════ -->
  <joint name="imu_jt" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="0.0 0.0 ${ch/2 + 0.05}" rpy="0 0 0"/>
  </joint>
  <link name="imu_link">
    <visual>
      <geometry><box size="0.038 0.028 0.005"/></geometry>
      <material name="pcb_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.006" rpy="0 0 0"/>
      <geometry><box size="0.010 0.010 0.004"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════
       U-BLOX GPS — on roof rear
       Attached to roof link so it moves with roof
  ═══════════════════════════════ -->
  <joint name="gps_jt" type="fixed">
    <parent link="roof"/><child link="gps_link"/>
    <origin xyz="-0.90 0.0 ${roof_t/2 + 0.010}" rpy="0 0 0"/>
  </joint>
  <link name="gps_link">
    <visual>
      <geometry><box size="0.065 0.065 0.015"/></geometry>
      <material name="gps_white"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.010" rpy="0 0 0"/>
      <geometry><cylinder radius="0.036" length="0.003"/></geometry>
      <material name="silver"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════
       HC-SR04 ULTRASONIC x4
       Blue PCB + 2 silver transducer circles
  ═══════════════════════════════ -->
  <xacro:macro name="us_sensor" params="name px py yaw">
    <joint name="${name}_jt" type="fixed">
      <parent link="base_link"/><child link="${name}"/>
      <origin xyz="${px} ${py} ${-ch/2 + 0.10}" rpy="0 0 ${yaw}"/>
    </joint>
    <link name="${name}">
      <visual>
        <geometry><box size="0.018 0.048 0.018"/></geometry>
        <material name="us_blue"/>
      </visual>
      <visual>
        <origin xyz="0.012 -0.012 0" rpy="0 1.5708 0"/>
        <geometry><cylinder radius="0.008" length="0.006"/></geometry>
        <material name="silver"/>
      </visual>
      <visual>
        <origin xyz="0.012  0.012 0" rpy="0 1.5708 0"/>
        <geometry><cylinder radius="0.008" length="0.006"/></geometry>
        <material name="silver"/>
      </visual>
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:us_sensor name="ultrasonic_front_link" px="${cl/2 - 0.04}" py="0.0"        yaw="0.0"/>
  <xacro:us_sensor name="ultrasonic_rear_link"  px="${-cl/2 + 0.04}" py="0.0"       yaw="3.14159"/>
  <xacro:us_sensor name="ultrasonic_left_link"  px="0.0"             py="${cw/2}"    yaw="1.5708"/>
  <xacro:us_sensor name="ultrasonic_right_link" px="0.0"             py="${-cw/2}"   yaw="-1.5708"/>

  <!-- ═══════════════════════════════
       GAZEBO SENSOR PLUGINS
  ═══════════════════════════════ -->

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/</namespace></ros>
      <left_joint>wrl_jt</left_joint>
      <right_joint>wrr_jt</right_joint>
      <wheel_separation>1.10</wheel_separation>
      <wheel_diameter>${wr * 2}</wheel_diameter>
      <max_wheel_torque>500</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples><resolution>1</resolution>
            <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range><min>0.10</min><max>30.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor type="camera" name="camera_sensor">
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera name="front_camera">
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>50.0</far></clip>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros><namespace>/</namespace></ros>
        <camera_name>camera</camera_name>
        <image_topic_name>image_raw</image_topic_name>
        <camera_info_topic_name>camera_info</camera_info_topic_name>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=imu/data</remapping></ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="gps_link">
    <sensor name="gps_sensor" type="gps">
      <update_rate>1</update_rate>
      <plugin name="gps_plugin" filename="libgazebo_ros_gps_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=gps/fix</remapping></ros>
        <frame_name>gps_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="ultrasonic_front_link">
    <sensor type="ray" name="us_front">
      <update_rate>10</update_rate>
      <ray><scan><horizontal><samples>3</samples><resolution>1</resolution>
        <min_angle>-0.0524</min_angle><max_angle>0.0524</max_angle></horizontal></scan>
        <range><min>0.02</min><max>2.0</max><resolution>0.001</resolution></range>
      </ray>
      <plugin name="us_front_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=ultrasonic/front</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>ultrasonic_front_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="ultrasonic_rear_link">
    <sensor type="ray" name="us_rear">
      <update_rate>10</update_rate>
      <ray><scan><horizontal><samples>3</samples><resolution>1</resolution>
        <min_angle>-0.0524</min_angle><max_angle>0.0524</max_angle></horizontal></scan>
        <range><min>0.02</min><max>2.0</max><resolution>0.001</resolution></range>
      </ray>
      <plugin name="us_rear_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=ultrasonic/rear</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>ultrasonic_rear_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="ultrasonic_left_link">
    <sensor type="ray" name="us_left">
      <update_rate>10</update_rate>
      <ray><scan><horizontal><samples>3</samples><resolution>1</resolution>
        <min_angle>-0.0524</min_angle><max_angle>0.0524</max_angle></horizontal></scan>
        <range><min>0.02</min><max>2.0</max><resolution>0.001</resolution></range>
      </ray>
      <plugin name="us_left_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=ultrasonic/left</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>ultrasonic_left_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="ultrasonic_right_link">
    <sensor type="ray" name="us_right">
      <update_rate>10</update_rate>
      <ray><scan><horizontal><samples>3</samples><resolution>1</resolution>
        <min_angle>-0.0524</min_angle><max_angle>0.0524</max_angle></horizontal></scan>
        <range><min>0.02</min><max>2.0</max><resolution>0.001</resolution></range>
      </ray>
      <plugin name="us_right_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=ultrasonic/right</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>ultrasonic_right_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>