<?xml version="1.0" ?>
<!--
  srm_campus.world  v3.0  —  PROFESSIONAL REALISTIC CAMPUS
  ──────────────────────────────────────────────────────────────
  Full SRM Trichy campus simulation with:
    • Real-looking SRM IST building (white multi-storey + portico + windows)
    • Real-looking SRM Hospital (multi-wing + triple arch gate + helipad)
    • Real-looking SRM Temple (blue gopuram tiers + compound wall + pond)
    • Buggy Hub (central dispatch bay with canopy)
    • Black tarmac roads with white dashes + yellow edge lines
    • Zebra crossings at every destination entrance
    • Street lamps every 8 m on both road sides
    • LiDAR walls along every road (solid 3 m, gives dense scan returns)
    • Extra internal roads: service road, parking lot, side paths
    • Roundabout at hub junction
    • Trees: palm + shade varieties mixed

  NODES (Gazebo world frame, matching map_graph.py v2):
    BUGGY_HUB  = (  0,   0)   centre of roundabout
    SRM_IST    = (  0,  50)   North
    SRM_HOSP   = ( 50,   0)   East
    SRM_TEMPLE = (  0, -50)   South

  Road widths:
    Main roads   : 8 m  (two lanes)
    Service roads: 4 m
    Parking bay  : 12 m wide
-->
<sdf version="1.6">
<world name="srm_campus">

  <!-- ═══════════════════════════════════════════
       PHYSICS
  ═══════════════════════════════════════════ -->

<physics name="ode_physics" default="true" type="ode">
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1.0</real_time_factor>
    <real_time_update_rate>1000</real_time_update_rate>
    <ode><solver><type>quick</type><iters>50</iters></solver></ode>
  </physics>

  <!-- ═══════════════════════════════════════════
       LIGHTING — bright Tamil Nadu daylight
  ═══════════════════════════════════════════ -->
  <light name="sun" type="directional">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 100 0 0.4 0</pose>
    <diffuse>1.0 0.97 0.88 1</diffuse>
    <specular>0.4 0.4 0.4 1</specular>
    <attenuation><range>3000</range><constant>0.9</constant><linear>0.005</linear><quadratic>0.0001</quadratic></attenuation>
    <direction>-0.3 0.05 -0.95</direction>
  </light>
  <light name="sky_fill" type="point">
    <pose>0 0 60 0 0 0</pose>
    <diffuse>0.55 0.65 0.75 1</diffuse>
    <specular>0.05 0.05 0.05 1</specular>
    <attenuation><range>1000</range><constant>0.4</constant><linear>0.003</linear><quadratic>0.0</quadratic></attenuation>
  </light>

  <!-- ═══════════════════════════════════════════
       GROUND — green grass + dirt patches
  ═══════════════════════════════════════════ -->
  <model name="ground_grass">
    <static>true</static>
    <link name="link">
      <collision name="col">
        <geometry><plane><normal>0 0 1</normal><size>300 300</size></plane></geometry>
        <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction></surface>
      </collision>
      <visual name="vis">
        <cast_shadows>false</cast_shadows>
        <geometry><plane><normal>0 0 1</normal><size>300 300</size></plane></geometry>
        <material>
          <ambient>0.18 0.38 0.10 1</ambient>
          <diffuse>0.22 0.45 0.13 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>
    </link>
  </model>

  <!-- ═══════════════════════════════════════════
       MAIN ROADS — 8 m wide black tarmac
       All at z=0.03 so they float above grass
  ═══════════════════════════════════════════ -->

  <!-- Road N: Hub→IST  40 m, centred at (0,25) -->
  <model name="road_N">
    <static>true</static><pose>0 25 0.03 0 0 0</pose>
    <link name="link">
      <collision name="col">
        <geometry><box><size>8.0 50.0 0.06</size></box></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="vis">
        <geometry><box><size>8.0 50.0 0.06</size></box></geometry>
        <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>
    </link>
  </model>

  <!-- Road E: Hub→HOSP  40 m, centred at (25,0) -->
  <model name="road_E">
    <static>true</static><pose>25 0 0.03 0 0 0</pose>
    <link name="link">
      <collision name="col">
        <geometry><box><size>50.0 8.0 0.06</size></box></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="vis">
        <geometry><box><size>50.0 8.0 0.06</size></box></geometry>
        <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>
    </link>
  </model>

  <!-- Road S: Hub→TEMPLE  40 m, centred at (0,-25) -->
  <model name="road_S">
    <static>true</static><pose>0 -25 0.03 0 0 0</pose>
    <link name="link">
      <collision name="col">
        <geometry><box><size>8.0 50.0 0.06</size></box></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="vis">
        <geometry><box><size>8.0 50.0 0.06</size></box></geometry>
        <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>
    </link>
  </model>

  <!-- ── YELLOW EDGE LINES (road shoulders) ── -->
  <!-- Road N left edge -->
  <model name="el_NL"><static>true</static><pose>-4.1 25 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.15 50 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.15 50 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>
  <model name="el_NR"><static>true</static><pose> 4.1 25 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.15 50 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.15 50 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>
  <!-- Road E top/bottom edges -->
  <model name="el_ET"><static>true</static><pose>25  4.1 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>50 0.15 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>50 0.15 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>
  <model name="el_EB"><static>true</static><pose>25 -4.1 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>50 0.15 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>50 0.15 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>
  <!-- Road S edges -->
  <model name="el_SL"><static>true</static><pose>-4.1 -25 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.15 50 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.15 50 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>
  <model name="el_SR"><static>true</static><pose> 4.1 -25 0.065 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.15 50 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.15 50 0.01</size></box></geometry><material><ambient>0.95 0.75 0.0 1</ambient><diffuse>0.95 0.75 0.0 1</diffuse></material></visual></link></model>

  <!-- ── WHITE CENTRE DASHES ── -->
  <!-- Road N dashes (Y axis) -->
  <model name="wn01"><static>true</static><pose>0  5 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn02"><static>true</static><pose>0 10 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn03"><static>true</static><pose>0 15 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn04"><static>true</static><pose>0 20 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn05"><static>true</static><pose>0 25 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn06"><static>true</static><pose>0 30 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn07"><static>true</static><pose>0 35 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn08"><static>true</static><pose>0 40 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="wn09"><static>true</static><pose>0 45 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>0.20 2.5 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>0.20 2.5 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <!-- Road E dashes (X axis) -->
  <model name="we01"><static>true</static><pose> 5 0 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>2.5 0.20 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>2.5 0.20 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="we02"><static>true</static><pose>10 0 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>2.5 0.20 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>2.5 0.20 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="we03"><static>true</static><pose>15 0 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>2.5 0.20 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>2.5 0.20 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
