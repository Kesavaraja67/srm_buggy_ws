  <!-- ═══════════════════════════════════════════
       SRM IST — NORTH (0, 50)
       Realistic multi-storey academic building:
       • Main 7-floor block (white)
       • Left + right wings (6-floor)
       • Round portico with pillars
       • Window grid (dark insets)
       • Entrance steps + ramp
       • Boundary wall + main gate arch
       • Parking lot in front
  ═══════════════════════════════════════════ -->

  <!-- IST parking lot -->
  <model name="ist_parking">
    <static>true</static><pose>0 54 0.04 0 0 0</pose>
    <link name="link">
