  <!-- ═══════════════════════════════════════════
       BUGGY HUB — central dispatch bay
       Yellow roundabout circle + shelter canopy
       + parking bays + signboard
  ═══════════════════════════════════════════ -->
  <!-- Roundabout tarmac disc -->
  <model name="roundabout_road">
    <static>true</static><pose>0 0 0.04 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><cylinder><radius>9.0</radius><length>0.08</length></cylinder></geometry></collision>
      <visual name="vis"><geometry><cylinder><radius>9.0</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
      </visual>
    </link>
  </model>
  <!-- Central island — green grass circle -->
  <model name="roundabout_island">
    <static>true</static><pose>0 0 0.10 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><cylinder><radius>4.5</radius><length>0.12</length></cylinder></geometry></collision>
      <visual name="vis"><geometry><cylinder><radius>4.5</radius><length>0.12</length></cylinder></geometry>
        <material><ambient>0.18 0.42 0.10 1</ambient><diffuse>0.22 0.50 0.12 1</diffuse></material>
      </visual>
    </link>
  </model>
  <!-- Central flagpole -->
  <model name="flagpole">
    <static>true</static><pose>0 0 5 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><cylinder><radius>0.08</radius><length>10</length></cylinder></geometry></collision>
      <visual name="vis"><geometry><cylinder><radius>0.08</radius><length>10</length></cylinder></geometry>
        <material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
      </visual>
    </link>
  </model>
  <!-- Flag top (orange = saffron) -->
  <model name="flag">
    <static>true</static><pose>1.5 0 9.8 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>3.0 0.1 1.5</size></box></geometry></collision>
      <visual name="vis"><geometry><box><size>3.0 0.1 1.5</size></box></geometry>
        <material><ambient>0.95 0.45 0.05 1</ambient><diffuse>0.95 0.45 0.05 1</diffuse></material>
      </visual>
    </link>
  </model>
  <!-- Buggy shelter canopy (to the side of roundabout) -->
  <model name="hub_shelter_roof">
    <static>true</static><pose>-13 0 4.5 0 0 0</pose>
    <link name="link">
      <collision name="col"><geometry><box><size>8 5 0.3</size></box></geometry></collision>
      <visual name="vis"><geometry><box><size>8 5 0.3</size></box></geometry>
        <material><ambient>0.10 0.30 0.65 1</ambient><diffuse>0.12 0.35 0.70 1</diffuse></material>
      </visual>
    </link>
  </model>
  <model name="hub_col1"><static>true</static><pose>-10 -2 2 0 0 0</pose><link name="l"><collision name="c"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry><material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material></visual></link></model>
  <model name="hub_col2"><static>true</static><pose>-10  2 2 0 0 0</pose><link name="l"><collision name="c"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry><material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material></visual></link></model>
  <model name="hub_col3"><static>true</static><pose>-16 -2 2 0 0 0</pose><link name="l"><collision name="c"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry><material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material></visual></link></model>
  <model name="hub_col4"><static>true</static><pose>-16  2 2 0 0 0</pose><link name="l"><collision name="c"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.2</radius><length>4</length></cylinder></geometry><material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material></visual></link></model>
  <!-- Buggy parking bay black strip -->
