  <!-- TEMPLE zebra (Y=-47) -->
  <model name="zeb_tem_1"><static>true</static><pose>-3 -47 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>1.5 1.0 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>1.5 1.0 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
  <model name="zeb_tem_2"><static>true</static><pose>-1 -47 0.07 0 0 0</pose><link name="l"><collision name="c"><geometry><box><size>1.5 1.0 0.01</size></box></geometry></collision><visual name="v"><geometry><box><size>1.5 1.0 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual></link></model>
